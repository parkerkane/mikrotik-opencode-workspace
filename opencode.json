{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mikrotik": {
      "type": "local",
      "command": [
        "python",
        "tools/mikrotik/main.py",
        "router.local"
      ],
      "environment": {
        "MIKROTIK_USER": "{env:MIKROTIK_USER}",
        "MIKROTIK_PASSWORD": "{env:MIKROTIK_PASSWORD}",
        "MIKROTIK_API_PASSWORDLESS_ENABLED": "{env:MIKROTIK_API_PASSWORDLESS_ENABLED}",
        "MIKROTIK_API_PASSWORDLESS_LENGTH": "{env:MIKROTIK_API_PASSWORDLESS_LENGTH}",
        "MIKROTIK_API_SSL": "{env:MIKROTIK_API_SSL}",
        "MIKROTIK_API_PORT": "{env:MIKROTIK_API_PORT}",
        "MIKROTIK_TLS_VERIFY": "{env:MIKROTIK_TLS_VERIFY}",
        "MIKROTIK_SCP_HOST": "{env:MIKROTIK_SCP_HOST}",
        "MIKROTIK_SCP_USER": "{env:MIKROTIK_SCP_USER}",
        "MIKROTIK_SCP_PASSWORD": "{env:MIKROTIK_SCP_PASSWORD}",
        "MIKROTIK_SCP_PRIVATE_KEY": "{env:MIKROTIK_SCP_PRIVATE_KEY}",
        "MIKROTIK_SCP_KEY_PASSPHRASE": "{env:MIKROTIK_SCP_KEY_PASSPHRASE}",
        "MIKROTIK_SCP_HOST_FINGERPRINT_SHA256": "{env:MIKROTIK_SCP_HOST_FINGERPRINT_SHA256}",
        "MIKROTIK_SCP_PORT": "{env:MIKROTIK_SCP_PORT}",
        "MIKROTIK_SCP_TIMEOUT": "{env:MIKROTIK_SCP_TIMEOUT}"
      },
      "enabled": true
    }
  }
}
